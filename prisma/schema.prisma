generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- better-auth core (table names via @@map) ---

model User {
  id            String   @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  members         Member[]
  invitationsSent Invitation[] @relation("invitation_inviter")

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id @default(cuid())
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@map("session")
}

/// OAuth / credential provider row (better-auth). Not the 3PL tenant account.
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// --- better-auth organization plugin ---

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  inviter        User         @relation("invitation_inviter", fields: [inviterId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@map("invitation")
}

// --- LogIQ tenancy (3PL operator account; maps 1:1 to better-auth Organization.id) ---

model LogiqAccount {
  id              String   @id @default(cuid())
  betterAuthOrgId String   @unique
  name            String
  slug            String   @unique
  plan            Plan     @default(STARTER)
  polarCustomerId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  warehouses    Warehouse[]
  merchants     Merchant[]
  users         AccountUser[]
  merchantUsers MerchantUser[]
  suppliers     Supplier[]
  purchaseOrders PurchaseOrder[]
  receivingRecords ReceivingRecord[]
  workOrders WorkOrder[]
  purchaseOrderAsns PurchaseOrderAsn[]
  orders        Order[]
  pickLists     PickList[]
  shipments     Shipment[]
  trackingEvents TrackingEvent[]
  carrierPerformanceLogs CarrierPerformanceLog[]
  merchantContracts MerchantContract[]
  feeRules      FeeRule[]
  slaRules      SLARule[]
  invoices      Invoice[]
  invoiceLines  InvoiceLine[]
  invoiceDisputes InvoiceDispute[]
  integrations  Integration[]
  apiKeys       ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  integrationSyncLogs IntegrationSyncLog[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  escalationRules EscalationRule[]
  pushSubscriptions PushSubscription[]
  labelTemplates  LabelTemplate[]
  generatedLabels GeneratedLabel[]
  packagingTypes PackagingType[]
  printQueues     PrintQueue[]
  thermalPrinters ThermalPrinter[]

  @@map("logiq_account")
}

model AccountUser {
  id               String     @id @default(cuid())
  accountId        String
  betterAuthUserId String     @unique
  systemRole       SystemRole
  email            String
  firstName        String?
  lastName         String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  account              LogiqAccount               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  warehouseAssignments WarehouseStaffAssignment[]
  managedWarehouses    WarehouseManager[]

  @@index([accountId])
  @@map("account_user")
}

model WarehouseStaffAssignment {
  id          String                @id @default(cuid())
  accountId   String
  userId      String
  warehouseId String
  permissions WarehousePermission[]
  assignedBy  String
  assignedAt  DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user      AccountUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([userId, warehouseId])
  @@index([accountId, warehouseId])
  @@map("warehouse_staff_assignment")
}

model WarehouseManager {
  id          String   @id @default(cuid())
  accountId   String
  userId      String
  warehouseId String
  assignedBy  String
  assignedAt  DateTime @default(now())

  user      AccountUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([userId, warehouseId])
  @@index([accountId, warehouseId])
  @@map("warehouse_manager")
}

model Warehouse {
  id           String   @id @default(cuid())
  accountId    String
  name         String
  code         String
  addressLine1 String
  city         String
  state        String
  zip          String
  country      String   @default("US")
  timezone     String   @default("America/Los_Angeles")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account            LogiqAccount               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  zones              Zone[]
  bins               Bin[]
  stockLevels        StockLevel[]
  stockMovements     StockMovement[]
  cycleCounts        CycleCount[]
  purchaseOrders     PurchaseOrder[]
  workOrders         WorkOrder[]
  orders             Order[]
  pickLists          PickList[]
  printQueues        PrintQueue[]
  thermalPrinters    ThermalPrinter[]
  staffAssignments   WarehouseStaffAssignment[]
  managerAssignments WarehouseManager[]

  @@unique([accountId, code])
  @@index([accountId])
  @@map("warehouse")
}

model Zone {
  id          String    @id @default(cuid())
  warehouseId String
  name        String
  code        String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bins        Bin[]

  @@index([warehouseId])
  @@map("zone")
}

model Bin {
  id          String   @id @default(cuid())
  zoneId      String
  warehouseId String
  label       String
  aisle       String
  rack        String
  level       String
  position    String
  maxWeight   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zone            Zone             @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockLevels     StockLevel[]
  cycleCountLines CycleCountLine[]
  outputWorkOrders WorkOrder[] @relation("WorkOrderOutputBin")
  receivingRecords ReceivingRecord[] @relation("ReceivingRecordPutawayBin")
  pickListItems   PickListItem[]

  @@index([warehouseId])
  @@map("bin")
}

// --- Merchants (portal); minimal for Module 2 invites ---

model Merchant {
  id        String   @id @default(cuid())
  accountId String
  name      String
  email     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  LogiqAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  users    MerchantUser[]
  products Product[]
  purchaseOrders PurchaseOrder[]
  workOrders WorkOrder[]
  orders   Order[]
  contract MerchantContract?
  invoices Invoice[]
  integrations Integration[]

  @@index([accountId])
  @@map("merchant")
}

model MerchantUser {
  id               String               @id @default(cuid())
  accountId        String
  merchantId       String
  betterAuthUserId String?              @unique
  systemRole       SystemRole
  permissions      MerchantPermission[]
  email            String
  firstName        String?
  lastName         String?
  invitedBy        String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  account  LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([accountId, merchantId])
  @@map("merchant_user")
}

model Product {
  id                String   @id @default(cuid())
  accountId         String
  merchantId        String
  name              String
  sku               String
  barcode           String?
  weightOz          Float?
  lengthIn          Float?
  widthIn           Float?
  heightIn          Float?
  lotTracking       Boolean  @default(false)
  serialTracking    Boolean  @default(false)
  expiryTracking    Boolean  @default(false)
  lowStockThreshold Int?
  deadStockDays     Int      @default(90)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  stockLevels     StockLevel[]
  movements       StockMovement[]
  cycleCountLines CycleCountLine[]
  purchaseOrderLines PurchaseOrderLine[]
  receivingRecords ReceivingRecord[]
  workOrderInputs WorkOrderInput[]
  outputWorkOrders WorkOrder[] @relation("WorkOrderOutputProduct")
  orderLines       OrderLine[]
  pickListItems    PickListItem[]

  @@unique([accountId, merchantId, sku])
  @@index([accountId, merchantId])
  @@map("product")
}

model StockLevel {
  id           String    @id @default(cuid())
  accountId    String
  productId    String
  binId        String
  warehouseId  String
  quantity     Int       @default(0)
  reservedQty  Int       @default(0)
  lotNumber    String?
  serialNumber String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  bin       Bin       @relation(fields: [binId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, binId, lotNumber, serialNumber])
  @@index([accountId, warehouseId])
  @@map("stock_level")
}

model StockMovement {
  id             String       @id @default(cuid())
  accountId      String
  productId      String
  warehouseId    String
  binId          String?
  type           MovementType
  quantityDelta  Int
  quantityBefore Int
  quantityAfter  Int
  referenceId    String?
  referenceType  String?
  lotNumber      String?
  reason         String?
  performedBy    String
  createdAt      DateTime     @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([accountId, productId])
  @@index([accountId, warehouseId])
  @@map("stock_movement")
}

model Supplier {
  id           String   @id @default(cuid())
  accountId    String
  name         String
  email        String?
  leadTimeDays Int      @default(7)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account        LogiqAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([accountId])
  @@map("supplier")
}

model PurchaseOrder {
  id               String            @id @default(cuid())
  accountId        String
  merchantId       String
  warehouseId      String
  supplierId       String
  poNumber         String
  status           POStatus          @default(DRAFT)
  expectedDate     DateTime?
  receivedAt       DateTime?
  notes            String?
  createdBy        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  account          LogiqAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant         Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  supplier         Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines            PurchaseOrderLine[]
  receivingRecords ReceivingRecord[]
  asns             PurchaseOrderAsn[]

  @@unique([accountId, poNumber])
  @@index([accountId, merchantId])
  @@index([accountId, warehouseId])
  @@map("purchase_order")
}

model PurchaseOrderLine {
  id            String        @id @default(cuid())
  poId          String
  productId     String
  orderedQty    Int
  receivedQty   Int           @default(0)
  unitCostCents Int?
  lotNumber     String?
  expiryDate    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@index([productId])
  @@map("purchase_order_line")
}

model ReceivingRecord {
  id              String        @id @default(cuid())
  accountId       String
  poId            String
  productId       String
  receivedQty     Int
  putawayBinId    String?
  receivedBy      String
  discrepancyNote String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  account LogiqAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  putawayBin Bin?       @relation("ReceivingRecordPutawayBin", fields: [putawayBinId], references: [id], onDelete: SetNull)

  @@index([accountId, poId])
  @@index([accountId, productId])
  @@map("receiving_record")
}

model WorkOrder {
  id              String          @id @default(cuid())
  accountId       String
  merchantId      String
  warehouseId     String
  woNumber        String
  type            WorkOrderType
  status          WorkOrderStatus @default(PENDING)
  targetQty       Int
  completedQty    Int             @default(0)
  outputProductId String?
  outputBinId     String?
  scheduledDate   DateTime?
  completedAt     DateTime?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  account       LogiqAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant      Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  outputProduct Product?       @relation("WorkOrderOutputProduct", fields: [outputProductId], references: [id], onDelete: SetNull)
  outputBin     Bin?           @relation("WorkOrderOutputBin", fields: [outputBinId], references: [id], onDelete: SetNull)
  inputLines    WorkOrderInput[]

  @@unique([accountId, woNumber])
  @@index([accountId, merchantId])
  @@index([accountId, warehouseId])
  @@map("work_order")
}

model WorkOrderInput {
  id          String    @id @default(cuid())
  workOrderId String
  productId   String
  qtyPerUnit  Int
  consumedQty Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([productId])
  @@map("work_order_input")
}

model PurchaseOrderAsn {
  id                  String    @id @default(cuid())
  accountId           String
  poId                String
  asnNumber           String
  expectedArrivalDate DateTime?
  status              AsnStatus @default(DRAFT)
  notes               String?
  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  account       LogiqAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@unique([accountId, asnNumber])
  @@index([accountId, poId])
  @@map("purchase_order_asn")
}

model Order {
  id                String            @id @default(cuid())
  accountId         String
  merchantId        String
  warehouseId       String?
  channelOrderId    String
  channel           String
  status            OrderStatus       @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  shippingName      String
  shippingLine1     String
  shippingCity      String
  shippingState     String
  shippingZip       String
  shippingCountry   String            @default("US")
  slaHours          Int?
  dueAt             DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  account   LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant  Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  warehouse Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  lines     OrderLine[]
  shipments Shipment[]
  pickList  PickList?
  pickListItems PickListItem[]
  printQueueItems PrintQueueItem[]

  @@unique([accountId, channelOrderId, channel])
  @@index([accountId, merchantId, status])
  @@index([accountId, warehouseId])
  @@map("order")
}

model OrderLine {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  sku       String
  quantity  Int
  pickedQty Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_line")
}

model PickList {
  id          String       @id @default(cuid())
  accountId   String
  warehouseId String
  strategy    PickStrategy
  status      PickStatus   @default(PENDING)
  assignedTo  String?
  startedAt   DateTime?
  completedAt DateTime?
  orderId     String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  account   LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  warehouse Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  order     Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items     PickListItem[]

  @@index([accountId, warehouseId, status])
  @@map("pick_list")
}

model PickListItem {
  id          String   @id @default(cuid())
  pickListId  String
  productId   String
  orderId     String
  binId       String
  binLabel    String
  requiredQty Int
  pickedQty   Int      @default(0)
  scannedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pickList PickList @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bin      Bin      @relation(fields: [binId], references: [id], onDelete: Cascade)

  @@index([pickListId])
  @@index([productId])
  @@map("pick_list_item")
}

model Shipment {
  id                 String         @id @default(cuid())
  accountId          String
  orderId            String
  easypostShipmentId String?        @unique
  carrier            String
  service            String
  trackingNumber     String?
  labelUrl           String?
  weightOz           Float?
  rateCents          Int?
  status             ShipmentStatus @default(LABEL_CREATED)
  shippedAt          DateTime?
  deliveredAt        DateTime?
  logiqRecommended   Boolean        @default(false)
  packagingTypeId    String?
  packagingCostCents Int?
  dimWeightOz        Float?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  account        LogiqAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  packagingType  PackagingType?   @relation(fields: [packagingTypeId], references: [id], onDelete: SetNull)
  trackingEvents TrackingEvent[]
  performanceLog CarrierPerformanceLog?
  printQueueItem PrintQueueItem?

  @@index([accountId, orderId])
  @@index([accountId, packagingTypeId])
  @@map("shipment")
}

model PackagingType {
  id           String   @id @default(cuid())
  accountId    String
  name         String
  lengthIn     Float
  widthIn      Float
  heightIn     Float
  maxWeightOz  Float
  tareWeightOz Float    @default(0)
  costCents    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account    LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shipments  Shipment[]
  printQueueItems PrintQueueItem[]

  @@index([accountId])
  @@map("packaging_type")
}

model TrackingEvent {
  id          String         @id @default(cuid())
  accountId   String
  shipmentId  String
  status      ShipmentStatus
  description String?
  eventAt     DateTime
  createdAt   DateTime       @default(now())

  account  LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shipment Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([accountId, shipmentId])
  @@map("tracking_event")
}

model CarrierPerformanceLog {
  id              String   @id @default(cuid())
  accountId       String
  shipmentId      String   @unique
  carrier         String
  service         String
  destinationZone Int?
  weightOz        Float
  promisedDays    Int?
  actualDays      Int?
  onTime          Boolean?
  damaged         Boolean  @default(false)
  rateCents       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account  LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  shipment Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([accountId, carrier])
  @@map("carrier_performance_log")
}

model MerchantContract {
  id            String        @id @default(cuid())
  accountId     String
  merchantId    String        @unique
  paymentPeriod PaymentPeriod @default(MONTHLY)
  currency      String        @default("USD")
  startDate     DateTime
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  account  LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  feeRules FeeRule[]
  slaRules SLARule[]
  invoices Invoice[]

  @@index([accountId, merchantId])
  @@map("merchant_contract")
}

model FeeRule {
  id            String   @id @default(cuid())
  accountId     String
  contractId    String
  feeType       FeeType
  rateCents     Int
  unitLabel     String
  includedUnits Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account  LogiqAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contract MerchantContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([accountId, contractId])
  @@map("fee_rule")
}

model SLARule {
  id            String   @id @default(cuid())
  accountId     String
  contractId    String
  metric        String
  thresholdMins Int
  warningPct    Int      @default(90)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account  LogiqAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contract MerchantContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([accountId, contractId])
  @@map("sla_rule")
}

model Invoice {
  id            String        @id @default(cuid())
  accountId     String
  merchantId    String
  contractId    String
  invoiceNumber String
  periodStart   DateTime
  periodEnd     DateTime
  status        InvoiceStatus @default(DRAFT)
  totalCents    Int           @default(0)
  anomalyFlags  Json?
  pdfUrl        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  account  LogiqAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  contract MerchantContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  lines    InvoiceLine[]
  disputes InvoiceDispute[]

  @@index([accountId, merchantId])
  @@map("invoice")
}

model InvoiceLine {
  id            String   @id @default(cuid())
  accountId     String
  invoiceId     String
  feeType       FeeType
  description   String
  unitCount     Int
  unitRateCents Int
  totalCents    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([accountId, invoiceId])
  @@map("invoice_line")
}

model InvoiceDispute {
  id             String   @id @default(cuid())
  accountId      String
  invoiceId      String
  submittedBy    String
  reason         String
  status         String   @default("OPEN")
  resolutionNote String?
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoice Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([accountId, invoiceId])
  @@map("invoice_dispute")
}

model Integration {
  id         String            @id @default(cuid())
  accountId  String
  merchantId String?
  type       IntegrationType
  status     IntegrationStatus @default(CONNECTED)
  credentials Json
  metadata   Json?
  lastSyncAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  account  LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchant Merchant?    @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  syncLogs IntegrationSyncLog[]

  @@unique([accountId, merchantId, type])
  @@map("integration")
}

model ApiKey {
  id         String    @id @default(cuid())
  accountId  String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, isActive])
  @@map("api_key")
}

model WebhookEndpoint {
  id         String    @id @default(cuid())
  accountId  String
  url        String
  secret     String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, url])
  @@index([accountId, isActive])
  @@map("webhook_endpoint")
}

model IntegrationSyncLog {
  id            String   @id @default(cuid())
  accountId     String
  integrationId String
  eventType     String
  status        String
  ordersFetched Int      @default(0)
  ordersUpserted Int     @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())

  account     LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  integration Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([accountId, integrationId, createdAt])
  @@map("integration_sync_log")
}

model Notification {
  id         String               @id @default(cuid())
  accountId  String
  userId     String?
  merchantId String?
  type       NotificationType
  severity   NotificationSeverity @default(INFO)
  title      String
  body       String
  data       Json?
  channel    NotificationChannel
  readAt     DateTime?
  sentAt     DateTime?
  failedAt   DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, userId, readAt])
  @@map("notification")
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  accountId String
  type      NotificationType
  inApp     Boolean  @default(true)
  email     Boolean  @default(true)
  slack     Boolean  @default(false)
  sms       Boolean  @default(false)
  push      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([accountId, userId])
  @@map("notification_preference")
}

model EscalationRule {
  id               String               @id @default(cuid())
  accountId        String
  severity         NotificationSeverity
  ackWindowMinutes Int                  @default(120)
  escalateTo       String[]
  escalateViaSms   Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, severity])
  @@index([accountId])
  @@map("escalation_rule")
}

model PushSubscription {
  id           String   @id @default(cuid())
  accountId    String
  userId       String
  endpoint     String
  subscription Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([accountId, userId])
  @@map("push_subscription")
}

model CycleCount {
  id            String      @id @default(cuid())
  accountId     String
  warehouseId   String
  name          String
  status        CycleStatus @default(DRAFT)
  scheduledDate DateTime?
  completedAt   DateTime?
  createdBy     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  lines     CycleCountLine[]

  @@index([accountId, warehouseId])
  @@map("cycle_count")
}

model CycleCountLine {
  id           String   @id @default(cuid())
  cycleCountId String
  productId    String
  binId        String
  expectedQty  Int
  countedQty   Int?
  discrepancy  Int?
  reconciled   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cycleCount CycleCount @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  bin        Bin        @relation(fields: [binId], references: [id], onDelete: Cascade)

  @@index([cycleCountId])
  @@index([productId, binId])
  @@map("cycle_count_line")
}

model LabelTemplate {
  id         String    @id @default(cuid())
  accountId  String
  name       String
  type       LabelType
  widthMm    Float     @default(101.6)
  heightMm   Float     @default(152.4)
  fields     Json
  logoUrl    String?
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  account   LogiqAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  generated GeneratedLabel[]

  @@index([accountId, type])
  @@map("label_template")
}

model GeneratedLabel {
  id            String   @id @default(cuid())
  accountId     String
  templateId    String
  referenceId   String
  referenceType String
  pdfUrl        String
  zplContent    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  account  LogiqAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  template LabelTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([accountId, referenceId])
  @@index([accountId, templateId])
  @@map("generated_label")
}

model PrintQueue {
  id              String           @id @default(cuid())
  accountId       String
  warehouseId     String
  name            String
  status          PrintQueueStatus @default(PENDING)
  labelCount      Int              @default(0)
  printedAt       DateTime?
  manifestFormUrl String?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  account   LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  warehouse Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  items     PrintQueueItem[]

  @@index([accountId, warehouseId])
  @@map("print_queue")
}

model PrintQueueItem {
  id              String          @id @default(cuid())
  queueId         String
  orderId         String
  easypostRateId  String
  weightOz        Float
  packagingTypeId String?
  shipmentId      String?         @unique
  status          PrintItemStatus @default(PENDING)
  errorMessage    String?
  labelUrl        String?
  zplContent      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  queue           PrintQueue      @relation(fields: [queueId], references: [id], onDelete: Cascade)
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipment        Shipment?       @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  packagingType   PackagingType?  @relation(fields: [packagingTypeId], references: [id], onDelete: SetNull)

  @@index([queueId])
  @@index([orderId])
  @@map("print_queue_item")
}

model ThermalPrinter {
  id          String   @id @default(cuid())
  accountId   String
  warehouseId String
  name        String
  ipAddress   String
  port        Int      @default(9100)
  labelWidth  Float    @default(101.6)
  labelHeight Float    @default(152.4)
  isOnline    Boolean  @default(false)
  lastPingAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account   LogiqAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  warehouse Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([accountId, warehouseId])
  @@map("thermal_printer")
}

